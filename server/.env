# MONGO_URI=mongodb://heriberto777:eli112910@localhost:27017/core_app

# JWT
JWT_SECRET="HG3y$obesey@vqtvja+nsf7xvbe2u&0#&!bift=1%g(al=z7k$w%EG"

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
