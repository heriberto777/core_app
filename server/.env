SERVER2_TRUST_SERVER_CERT=true
SERVER2_INSTANCE=null

# Debug
# DEBUG=ioredis:*,tedious:*

# Configuración de reintentos
RETRY_ATTEMPTS=3
RETRY_DELAY=5000

# Configuración de lotes
BATCH_SIZE=100
INSERT_BATCH_SIZE=50

# Nivel general de logs
LOG_LEVEL=error

# Niveles específicos por transporte
CONSOLE_LOG_LEVEL=debug
FILE_LOG_LEVEL=info
MONGO_LOG_LEVEL=info

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://catelli.ddns.net
