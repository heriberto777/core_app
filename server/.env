# Entorno — Fix: NODE_ENV estaba duplicado (production y development). Se unifica.
NODE_ENV=development

# Información del servicio
SERVICE_NAME=transfer-control
npm_package_version=1.0.0

# Puerto
PORT=3979

# API versión
API_VERSION=v1

# Modo servidor (http o https)
SERVER_MODE=https
DISABLE_SSL=true

# SSL (solo para HTTPS en producción)
SSL_KEY_PATH=/etc/letsencrypt/live/catelli.ddns.net/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/catelli.ddns.net/fullchain.pem
SSL_CA_PATH=/etc/letsencrypt/live/catelli.ddns.net/chain.pem

DISABLE_MONGO_LOGS=false

# MongoDB
DB_USER=heriberto777
DB_PASS=eli112910
DB_PORT=27017
DB_HOST=127.0.0.1
DB_NAME=core_app
