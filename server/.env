# SQL Server 1 (Origen - CATELLI/Exactus)
SERVER1_USER=sa
SERVER1_PASS="Mercedes@262"
SERVER1_HOST=10.0.10.120
SERVER1_DB=EXACTUS
SERVER1_PORT=1433
SERVER1_ENCRYPT=false
SERVER1_TRUST_SERVER_CERT=true

# SQL Server 2 (Destino - TELYNET/Integración)
# NOTA: En desarrollo apuntan al mismo host. En producción suelen ser distintos.
SERVER2_USER=sa
SERVER2_PASS="Mercedes@262"
